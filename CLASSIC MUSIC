    let currentMusician = null;

    function buildMainScreen() {
      const eraContainer = document.getElementById('eraContainer');
      eraContainer.innerHTML = '';

      eraGroups.forEach(group => {
        const section = document.createElement('div');
        section.className = 'era-section';

        const title = document.createElement('h2');
        title.className = 'era-title';
        title.innerText = group.icon + ' ' + group.era;

        const desc = document.createElement('p');
        desc.className = 'era-desc';
        desc.innerText = group.desc;

        const grid = document.createElement('div');
        grid.className = 'musician-grid';

        group.musicians.forEach(name => {
          const data = musicians[name];
          const card = document.createElement('div');
          card.className = 'card';
          card.onclick = () => openChat(name);
          card.innerHTML = `
            <img src="${data.photo}" alt="${data.name}" onerror="this.src='https://via.placeholder.com/132x132?text=Music'">
            <h2>${data.name}</h2>
            <p>${data.country}</p>
            <p>🎵 ${data.nickname}</p>
          `;
          grid.appendChild(card);
        });

        section.appendChild(title);
        section.appendChild(desc);
        section.appendChild(grid);
        eraContainer.appendChild(section);
      });
    }

    function openChat(name) {
      currentMusician = musicians[name];

      document.getElementById('mainScreen').classList.remove('active');
      document.getElementById('chatScreen').classList.add('active');
      document.getElementById('chatName').innerText = currentMusician.name + '와 채팅하기';
      document.getElementById('chatEra').innerText = currentMusician.era + ' · ' + currentMusician.nickname;
      document.getElementById('chatPhoto').src = currentMusician.photo;

      const chatBox = document.getElementById('chatBox');
      chatBox.innerHTML = '';
      addMessage('안녕 나는 ' + currentMusician.name + '야 😊
' + currentMusician.simpleInfo, 'bot');
      addMessage('궁금한 걸 물어봐 🎼
예: 대표곡에 대해 설명해줘 / 이 시대 음악 특징은 뭐야 / 재미있는 이야기 알려줘', 'bot');
    }

    function goMain() {
      document.getElementById('chatScreen').classList.remove('active');
      document.getElementById('mainScreen').classList.add('active');
      document.getElementById('userInput').value = '';
    }

    function askQuick(text) {
      document.getElementById('userInput').value = text;
      sendMessage();
    }

    function sendMessage() {
      const input = document.getElementById('userInput');
      const text = input.value.trim();
      if (text === '' || !currentMusician) return;

      addMessage(text, 'user');
      input.value = '';

      setTimeout(() => {
        addMessage(makeAnswer(text), 'bot');
      }, 350);
    }

    function handleEnter(event) {
      if (event.key === 'Enter') {
        sendMessage();
      }
    }

    function addMessage(text, type) {
      const chatBox = document.getElementById('chatBox');
      const message = document.createElement('div');
      message.className = 'message ' + type;
      message.innerText = text;
      chatBox.appendChild(message);
      chatBox.scrollTop = chatBox.scrollHeight;
    }

