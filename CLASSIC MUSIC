          return '낭만주의 음악은 감정과 상상력을 중요하게 생각해요 🌙
사랑, 슬픔, 기쁨, 이야기 같은 마음속 느낌을 음악으로 표현했어요.
' + data.name + '와 연결해서 보면 이렇게 이해할 수 있어요.
' + data.eraInfo;
        }
        return data.eraInfo + '

' + data.name + '의 음악 특징은 ' + data.style;
      }

      if (hasAny(q, ['악기', '연주'])) {
        return data.qa['악기'];
      }

      if (hasAny(q, ['어떤사람', '성격', '사람이야', '인물'])) {
        return data.qa['어떤 사람'];
      }

      if (hasAny(q, ['왜유명', '유명한이유', '중요한이유'])) {
        return data.qa['왜 유명'];
      }

      if (hasAny(q, ['재미', '이야기', '일화'])) {
        return data.qa['재미있는 이야기'];
      }

      if (hasAny(q, ['초등', '교과', '수업', '학교'])) {
        return data.qa['초등'];
      }

      if (hasAny(q, ['나라', '어디', '출신'])) {
        return data.name + '는 ' + data.country + ' 음악가예요 🌍';
      }

      if (hasAny(q, ['별명'])) {
        return data.name + '의 별명은 ' + data.nickname + '이에요 ✨';
      }

      if (hasAny(q, ['설명', '소개', '누구'])) {
        return data.simpleInfo + '

대표곡은 ' + data.famousSongs.join(', ') + ' 등이 있어요 🎵';
      }

      return '좋은 질문이야 😊
나는 ' + data.name + '에 대해 이렇게 알려줄 수 있어.

🎵 대표곡: ' + data.famousSongs.join(', ') + '
🏛️ 시대: ' + data.era + '
🌍 나라: ' + data.country + '
✨ 특징: ' + data.style + '

대표곡, 시대 특징, 악기, 재미있는 이야기, 퀴즈 중에서 물어봐 줘!';
    }

    function hasAny(text, words) {
      return words.some(word => text.includes(word));
    }

    buildMainScreen();
  </script>
</body>
